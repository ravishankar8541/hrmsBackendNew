<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <style>
        @page {
    margin: 8mm 10mm;  /* Reduced from 12mm to 8mm */
    size: A4 portrait;
}

body {
    font-family: Arial, Helvetica, sans-serif;
    color: #000;
    font-size: 12px;
    line-height: 1.4;
    margin: 0;
    padding: 0;
}

table {
    border-collapse: collapse;
    width: 100%;
}

/* Header - Company Info */
.header {
    margin-top: -30px;  /* Changed from -40px to -30px */
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.logo {
    height: 120px;  /* Reduced from 150px */
    width: auto;
    object-fit: contain;
    margin-bottom: 0;  /* REMOVED negative margin */
}

.company-info {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-end;
    text-align: right;
    margin-bottom: 0;  /* REMOVED 50px margin */
}

.company-name {
    font-size: 18px;
    font-weight: bold;
    text-transform: uppercase;
    margin: 0;
}

.company-address {
    font-size: 10px;
    color: #333;
    margin: 3px 0 0;
}

/* Title */
.title {
    text-align: center;
    margin: 5px 0 10px;  /* Reduced from 10px 0 15px */
}

.title h1 {
    font-size: 20px;
    font-weight: bold;
    text-transform: uppercase;
    border-top: 1px solid #000;
    padding-bottom: 4px;
    padding-top: 10px;  /* Reduced from 15px */
    margin: 5px 0;  /* Added to reduce space */
}

.title .month {
    font-size: 13px;
    font-weight: bold;
    margin-top: 2px;
    margin-bottom: 5px;
}

/* Employee Table */
.employee-table {
    width: 100%;
    border: 1px solid #000;
    border-collapse: collapse;
    font-size: 12px;
    margin-bottom: 8px;  /* Reduced from 12px */
}

.employee-table td {
    padding: 4px 8px;  /* Reduced from 6px 8px */
    border: 1px solid #000;
    vertical-align: top;
}

.employee-table tr.attendance td {
    border-top: 1px dashed #666;
    padding-top: 5px;  /* Reduced from 8px */
}

/* Salary Table */
.salary-table {
    border: 1px solid #000;
    font-size: 12px;
    margin: 15px 0;  /* Reduced from 25px */
}

.salary-table th {
    background: #000;
    color: #fff;
    padding: 4px 8px;  /* Reduced from 6px 8px */
    text-align: left;
    font-weight: bold;
}

.salary-table td {
    padding: 4px 8px;  /* Reduced from 6px 8px */
    border: 1px solid #ccc;
}

.amount-col {
    text-align: right;
    width: 90px;
}

.total-row {
    background: #f5f5f5;
    font-weight: bold;
}

/* Net Pay Box */
.net-pay-box {
    margin-top: 20px;  /* CHANGED from 120px to 20px */
    text-align: right;
}

.net-inner {
    display: inline-block;
    background: #000;
    color: #fff;
    padding: 8px 20px;  /* Reduced from 10px 20px */
    min-width: 200px;  /* Reduced from 220px */
    text-align: center;
}

.net-value {
    font-size: 18px;  /* Reduced from 20px */
    font-weight: bold;
    margin: 2px 0;
}

.net-words {
    font-size: 13px;  /* Reduced from 15px */
    opacity: 1.9;
}

/* Signatures - FIXED */
.signatures {
    margin-top: 30px;  /* CHANGED from 60px to 30px */
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    font-size: 11px;
}

.sig-left,
.sig-right {
    width: 40%;
    text-align: center;
}

.sig-line {
    border-top: 1px solid #000;
    margin: 30px auto 8px;  /* Reduced from 40px */
    width: 80%;
}
    </style>
</head>

<body>
    <!-- Header - Company left, Logo right (exact PDF layout) -->
    <div class="header">
        <img src="<%= logo %>" alt="Viral Ads Media" class="logo">

        <div class="company-info">
            <div class="company-name">VIRAL ADS MEDIA</div>
            <div class="company-address">
                B-27, Budh Vihar Phase 1, New Delhi-110086
            </div>
        </div>
    </div>


    <!-- Title -->
    <div class="title">
        <h1>SALARY PAYSLIP</h1>
        <div class="month">For the month of <%= payMonth || '—' %>
        </div>
    </div>

    <!-- Employee Information - Exact bordered multi-column table as in your PDF -->
    <table class="employee-table">
        <tr>
            <td><strong>Employee Name:</strong>
                <%= employeeName || '—' %>
            </td>
            <td><strong>Emp ID:</strong>
                <%= employeeId || '—' %>
            </td>
            <td><strong>Designation:</strong>
                <%= designation || '—' %>
            </td>
        </tr>
        <tr>
            <td><strong>DOJ:</strong>
                <%= joiningDate || '—' %>
            </td>
            <td><strong>PAN No:</strong>
                <%= panNumber || '—' %>
            </td>
            <td><strong>Aadhaar No:</strong>
                <%= aadharNumber || '—' %>
            </td>
        </tr>
        <tr>
            <td><strong>Bank A/c No:</strong>
                <%= bankAccount || '—' %>
            </td>
            <td><strong>IFSC Code:</strong>
                <%= ifsc || '—' %>
            </td>
            <td><strong>Phone:</strong>
                <%= phone || '—' %>
            </td>
        </tr>
        <!-- Attendance row with dotted separator (exact PDF style) -->
        <tr>
            <td><strong>NOD (No. of Days):</strong>
                <%= workingDays || 30 %>
            </td>
            <td><strong>NDP (Days Present):</strong>
                <%= (Number(workingDays || 30) - Number(lopDays || 0)) %>
            </td>
            <td> <strong>LOP Days:</strong>
                <%= lopDays || 0 %>
            </td>
        </tr>

    </table>

    <!-- Salary Table - Exact match to your PDF -->
    <table class="salary-table">
        <thead>
            <tr>
                <th>Earnings</th>
                <th class="amount-col">Amount (₹)</th>
                <th>Deductions</th>
                <th class="amount-col">Amount (₹)</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>Basic Salary</td>
                <td class="amount-col">
                    <%= basicSalary || '0' %>

                </td>
                <td>Loss of Pay (LOP)</td>
                <td class="amount-col">
                    <%= lopAmount || '0' %>
                </td>
            </tr>
            <tr>
                <td>Allowance</td>
                <td class="amount-col">
                    <%= allowance || '0' %>
                </td>
                <td>Other Deduction</td>
                <td class="amount-col">
                    <%= otherDeduction || '0' %>
                </td>
            </tr>
            <tr>
                <td>Bonus</td>
                <td class="amount-col">
                    <%= bonus || '0' %>
                </td>
                <td></td>
                <td class="amount-col"></td>
            </tr>
            <tr class="total-row">
                <td>Gross Earnings</td>
                <td class="amount-col">₹<%= grossEarnings || '0' %>
                </td>
                <td>Total Deductions</td>
                <td class="amount-col">₹<%= totalDeductions || '0' %>
                </td>
            </tr>
        </tbody>
    </table>

    <!-- Net Pay Box - Exact black box with text layout as in your PDF -->
    <div class="net-pay-box">
        <div class="net-inner">
            <div class="net-value">Net Pay: ₹ <%= netPayable || '0' %>
            </div>
            <div class="net-words">(Rupees <%= netPayWords || '0' %> Only)</div>
        </div>
    </div>

    <!-- Signatures - Exact as in your PDF -->
   <table style="width:100%; margin-top:280px; text-align:center;">
    <tr>
        <td style="width:50%;">
            <div style="border-top:1px solid #000; width:60%; margin:40px auto 10px;"></div>
            <strong>Employee Signature</strong>
        </td>

        <td style="width:50%;">
            <div style="border-top:1px solid #000; width:60%; margin:40px auto 10px;"></div>
            <strong>Authorised Signatory</strong><br>
            <span>For Viral Ads Media</span>
        </td>
    </tr>
</table>


</body>

</html>