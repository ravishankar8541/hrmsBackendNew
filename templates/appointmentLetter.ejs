<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <style>
        @page {
            size: A4;
            margin: 0;
        }
        body {
            font-family: 'Times New Roman', Times, serif;
            color: #1a1a1a;
            margin: 0;
            padding: 0;
            line-height: 1.3;  /* Kam kiya */
            font-size: 11.5px;  /* Chhota font */
        }
        .page-container {
            padding: 0.3in 0.5in;  /* Kam padding */
            min-height: 11.6in;
            position: relative;
            box-sizing: border-box;
            display: flex;
            flex-direction: column;
            background-color: #fff;
        }
        .page-break {
            page-break-before: always;
        }
        .header-table {
            width: 100%;
            border-bottom: 3px solid #f27022;
            padding-bottom: 8px;
            margin-bottom: 10px;
        }
        .logo-box {
            width: 180px;  /* Chhota logo */
        }
        .logo {
            width: 100%;
            height: auto;
        }
        .ref-info {
            text-align: right;
            font-size: 11px;
            color: #444;
            font-weight: bold;
        }
        .document-title {
            text-align: center;
            font-size: 20px;  /* Chhota title */
            font-weight: bold;
            margin: 8px 0;
            text-transform: uppercase;
            letter-spacing: 2px;
        }
        .section-accent {
            border-left: 4px solid #f27022;
            padding-left: 12px;
            margin: 8px 0;
        }
        .section-title {
            font-weight: bold;
            font-size: 14px;  /* Chhota */
            color: #f27022;
            text-transform: uppercase;
            margin: 12px 0 6px 0;
        }
        .content-body {
            font-size: 11.5px;
            text-align: justify;
        }
        .recipient-block {
            font-size: 12px;
            line-height: 1.3;
            margin-bottom: 10px;
        }
        .highlight {
            font-weight: bold;
            color: #000;
        }
        .clause-item {
            margin-bottom: 4px;  /* Kam spacing */
            display: table;
            width: 100%;
        }
        .clause-num {
            display: table-cell;
            width: 35px;  /* Kam */
            font-weight: bold;
            vertical-align: top;
        }
        .clause-text {
            display: table-cell;
            vertical-align: top;
        }
        .signature-wrapper {
            margin-top: 30px;  /* Kam */
            padding-bottom: 0.3in;
        }
        .sig-table {
            width: 100%;
            margin-top: 10px;
        }
        .footer {
            position: absolute;
            bottom: 0.3in;
            left: 0.5in;
            right: 0.5in;
            text-align: center;
            font-size: 10px;
            border-top: 1px solid #eee;
            padding-top: 8px;
            color: #666;
        }
        /* List items ko compact karo */
        ul, ol {
            margin: 2px 0;
            padding-left: 20px;
        }
        li {
            margin-bottom: 2px;
        }
        p {
            margin: 4px 0;
        }
    </style>
</head>
<body>

<!-- ===== PAGE 1 ===== -->
<div class="page-container">
    <!-- Header -->
    <table class="header-table">
        <tr>
            <td class="logo-box"><img src="<%= logo %>" class="logo"></td>
            <td class="ref-info">
                Ref No: <%= offerId %><br>
                Date: <%= currentDate %>
            </td>
        </tr>
    </table>

    <div class="content-body">
        <!-- Address -->
        <div class="recipient-block">
            To,<br>
            <strong><%= employeeName %></strong><br>
            S/O Mr. <%= fathersName %><br>
            <%= address %><br>
            <%= phone %><br>
            <%= email %>
        </div>

        <!-- Title -->
        <div class="document-title">Appointment Letter</div>

        <!-- Subject -->
        <div class="section-accent">
            <p style="margin: 0;"><strong>Subject: Appointment for the post of <%= position %></strong></p>
        </div>

        <!-- Intro -->
        <p>Dear <strong><%= employeeName.split(' ')[0] %></strong>,</p>
        <p>We are pleased to offer you the position of <span class="highlight"><%= position %></span> with <span class="highlight">VIRAL ADS MEDIA</span> on the following terms and conditions:</p>

        <!-- Clauses 1-5 -->
        <div class="clause-item">
            <div class="clause-num">1.</div>
            <div class="clause-text"><span class="highlight">Commencement:</span> Your employment will be effective as of <span class="highlight"><%= formattedJoiningDate %></span>.</div>
        </div>
        <div class="clause-item">
            <div class="clause-num">2.</div>
            <div class="clause-text"><span class="highlight">Job title:</span> Your job title will be <span class="highlight"><%= position %></span> and you will report to your Manager.</div>
        </div>
        <div class="clause-item">
            <div class="clause-num">3.</div>
            <div class="clause-text"><span class="highlight">Salary:</span> You will draw a gross stipend of <span class="highlight">Rs. <%= formattedSalary %>/- Per Month</span>.</div>
        </div>
        <div class="clause-item">
            <div class="clause-num">4.</div>
            <div class="clause-text"><span class="highlight">Place of posting:</span> You will be posted at Rohini, Delhi. You may however be required to work at any place of business which the Company has, or may later acquire.</div>
        </div>
        <div class="clause-item">
            <div class="clause-num">5.</div>
            <div class="clause-text"><span class="highlight">Nature of duties:</span> You will perform to the best of your ability all the duties as are inherent in your post and such additional duties as the company may call upon you to perform, from time to time.</div>
        </div>

        <!-- Section: Office Hours -->
        <div class="section-title">Office Hours Rules and Regulations</div>
        
        <div class="clause-item">
            <div class="clause-num">1.</div>
            <div class="clause-text"><span class="highlight">Office Timings:</span> Employees must report no later than 9:30 AM and should not leave before 6:30 PM without prior permission. A grace period of 10 minutes (up to 9:40 AM) is allowed only twice a month.</div>
        </div>
        <div class="clause-item">
            <div class="clause-num">2.</div>
            <div class="clause-text"><span class="highlight">Attendance:</span> Three late marks in a month will result in a half-day leave deduction. Biometric attendance is mandatory.</div>
        </div>
        <div class="clause-item">
            <div class="clause-num">3.</div>
            <div class="clause-text"><span class="highlight">Leave Policy:</span> All leaves must be pre-approved. Emergency leaves must be informed before 09:00 AM. Unapproved leave will be marked as LWP.</div>
        </div>
        <div class="clause-item">
            <div class="clause-num">4.</div>
            <div class="clause-text"><span class="highlight">Sandwich Leave:</span> If employee takes leave on both sides of a weekend or holiday, all consecutive days including the weekend/holiday will be counted as leave.</div>
        </div>
        <div class="clause-item">
            <div class="clause-num">5.</div>
            <div class="clause-text"><span class="highlight">Early Leave:</span> Early leave or late arrival beyond 2 hours without approval will be marked as half-day.</div>
        </div>
        <div class="clause-item">
            <div class="clause-num">6.</div>
            <div class="clause-text"><span class="highlight">Work Discipline:</span> No personal work during office hours. Maintain workplace decorum and professional environment.</div>
        </div>
        <div class="clause-item">
            <div class="clause-num">7.</div>
            <div class="clause-text"><span class="highlight">Rule Violation:</span> Verbal warning for first violation. Written warning for repeated violations. Continued disregard may lead to suspension or termination.</div>
        </div>
        <div class="clause-item">
            <div class="clause-num">8.</div>
            <div class="clause-text"><span class="highlight">Company property:</span> You will maintain in good condition Company property entrusted to you and shall return all such property prior to relinquishment of your charge.</div>
        </div>
        <div class="clause-item">
            <div class="clause-num">9.</div>
            <div class="clause-text"><span class="highlight">Borrowing/gifts:</span> You will not borrow or accept any money, gift, reward or compensation for personal gains from any person/client.</div>
        </div>
    </div>

    <div class="footer">
        Viral Ads Media - Registered Office | B-27, Budh Vihar Phase 1, New Delhi-86 | Tel-9354491934
    </div>
</div>

<!-- ===== PAGE 2 ===== -->
<div class="page-break"></div>
<div class="page-container">
    <div class="content-body">
        <!-- Section: Termination -->
        <div class="section-title">Termination</div>
        
        <div class="clause-item">
            <div class="clause-num">10.1</div>
            <div class="clause-text">You may terminate your employment by giving no less than <span class="highlight">30 Days</span> prior notice or salary for unsaved period.</div>
        </div>
        <div class="clause-item">
            <div class="clause-num">10.2</div>
            <div class="clause-text">The Company reserves the right to terminate your employment summarily without any notice period if guilty of misconduct, negligence, or fundamental breach of contract.</div>
        </div>
        <div class="clause-item">
            <div class="clause-num">10.3</div>
            <div class="clause-text">On termination, you will return to the Company all property, documents, and Confidential Information in your possession.</div>
        </div>

        <!-- Section: Confidential Information -->
        <div class="section-title">Confidential Information</div>
        
        <div class="clause-item">
            <div class="clause-num">11.1</div>
            <div class="clause-text">During employment, you will devote your whole time and attention to the Company's business. You shall not engage in any other business without prior permission.</div>
        </div>
        <div class="clause-item">
            <div class="clause-num">11.2</div>
            <div class="clause-text">You must maintain the highest degree of confidentiality and keep as confidential the records, documents and other Confidential Information relating to the business of the Company.</div>
        </div>
        <div class="clause-item">
            <div class="clause-num">11.3</div>
            <div class="clause-text">At no time, will you remove any Confidential Information from the office without permission.</div>
        </div>
        <div class="clause-item">
            <div class="clause-num">11.4</div>
            <div class="clause-text">Your duty to safeguard Confidential Information will survive the expiration or termination of your employment.</div>
        </div>
        <div class="clause-item">
            <div class="clause-num">11.5</div>
            <div class="clause-text">Breach of confidentiality will render you liable to summary dismissal in addition to any other remedy.</div>
        </div>

        <!-- Section: Notice Period -->
        <div class="section-title">Notice Period</div>
        
        <div class="clause-item">
            <div class="clause-num">12.</div>
            <div class="clause-text">This offer includes a mandatory notice period of 30 days. You are required to provide 30 days' written notice prior to your intended last working day. Salary will be disbursed within 45 days from the employee's last working day.</div>
        </div>
        <div class="clause-item">
            <div class="clause-num">13.</div>
            <div class="clause-text"><span class="highlight">Handover:</span> Hand over all files and assets properly. Failure to do so may result in withholding of final settlement.</div>
        </div>
        <div class="clause-item">
            <div class="clause-num">14.</div>
            <div class="clause-text"><span class="highlight">Company Policy:</span> The Company shall be entitled to make policy declarations from time to time and may alter the same at its sole discretion.</div>
        </div>
        <div class="clause-item">
            <div class="clause-num">15.</div>
            <div class="clause-text"><span class="highlight">Governing Law:</span> Your employment is subject to Indian laws. All disputes shall be subject to the jurisdiction of High Court, Delhi only.</div>
        </div>
        <div class="clause-item">
            <div class="clause-num">16.</div>
            <div class="clause-text"><span class="highlight">Acceptance:</span> Please confirm your acceptance of this Contract of Employment by signing and returning the duplicate copy.</div>
        </div>

        <!-- Signature -->
        <div class="signature-wrapper">
            <p>We welcome you, and look forward to receiving your acceptance and to working with you.</p>
            <table class="sig-table">
                <tr>
                    <td>
                        <p>Yours Sincerely,<br>For <strong>Viral Ads Media</strong></p>
                        <div style="height: 40px;"></div>
                        <div style="border-top: 1.5px solid #000; width: 200px; padding-top: 4px;">
                            Authorized Signatory
                        </div>
                    </td>
                    <td style="text-align: right;">
                        <p>Accepted & Agreed</p>
                        <div style="height: 40px;"></div>
                        <div style="border-top: 1.5px solid #000; width: 200px; margin-left: auto; padding-top: 4px;">
                            Employee Signature
                        </div>
                    </td>
                </tr>
            </table>
        </div>
    </div>

    <div class="footer">
        Viral Ads Media - Registered Office | B-27, Budh Vihar Phase 1, New Delhi-86 | Tel-9354491934
    </div>
</div>

</body>
</html>